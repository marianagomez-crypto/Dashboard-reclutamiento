# =============================================================================
# BALDECASH RECRUITMENT — Variables de entorno
# =============================================================================
# Copia este archivo a .env.local y completa los valores reales.
# NUNCA subas .env.local a git.
# -----------------------------------------------------------------------------

# --- Modo de datos ---
# "mock"    -> usa datos simulados en memoria (ideal para desarrollar la UI)
# "airtable"-> consume datos reales desde Airtable (requiere credenciales abajo)
DATA_SOURCE="mock"

# --- Airtable ---
# Genera un Personal Access Token desde:
#   https://airtable.com/create/tokens
# Scopes requeridos:
#   - data.records:read
#   - data.records:write
#   - schema.bases:read
# Acceso: agrega la(s) base(s) que la plataforma va a consumir.
AIRTABLE_TOKEN=""

# Base ID (empieza con "app...")
# Lo encuentras en https://airtable.com/api o en la URL de la base.
AIRTABLE_BASE_ID=""

# Nombres EXACTOS de las tablas (sensibles a mayusculas)
AIRTABLE_TABLE_CANDIDATES="Candidatos"
AIRTABLE_TABLE_VACANCIES="Vacantes"
AIRTABLE_TABLE_INTERVIEWS="Entrevistas"
AIRTABLE_TABLE_SOURCES="Fuentes"
AIRTABLE_TABLE_USERS="Usuarios"
AIRTABLE_TABLE_ACTIVITY="Actividad"

# --- Autenticacion ---
# Secreto JWT (genera uno fuerte, p.ej. `openssl rand -base64 48`)
AUTH_SECRET="cambia-este-secreto-por-uno-de-al-menos-48-caracteres-aleatorios"

# Duracion de sesion en segundos (default 8h)
AUTH_SESSION_TTL="28800"

# --- Admin bootstrap (modo mock) ---
# Credenciales iniciales del super-admin cuando DATA_SOURCE="mock"
ADMIN_EMAIL="admin@baldecash.com"
ADMIN_PASSWORD="Baldecash2026!"

# --- App ---
NEXT_PUBLIC_APP_NAME="Baldecash Recruitment"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
